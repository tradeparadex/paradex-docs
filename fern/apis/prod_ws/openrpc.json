    {
      "name": "order.modify",
      "summary": "Modify an existing open order",
      "description": "Updates the price and/or size of an open order. A new Starknet signature over the updated order payload is required.",
      "tags": [
        {
          "name": "Order Management"
        }
      ],
      "paramStructure": "by-name",
      "params": [
        {
          "name": "id",
          "description": "Order ID to modify",
          "required": true,
          "schema": {
            "example": "1234567890",
            "type": "string"
          }
        },
        {
          "name": "market",
          "description": "Market symbol of the existing order",
          "required": true,
          "schema": {
            "example": "BTC-USD-PERP",
            "type": "string"
          }
        },
        {
          "name": "side",
          "description": "Existing side of the order",
          "required": true,
          "schema": {
            "enum": [
              "BUY",
              "SELL"
            ],
            "type": "string"
          }
        },
        {
          "name": "type",
          "description": "Existing type of the order",
          "required": true,
          "schema": {
            "enum": [
              "LIMIT",
              "MARKET",
              "STOP_LIMIT",
              "STOP_MARKET"
            ],
            "type": "string"
          }
        },
        {
          "name": "size",
          "description": "New (or unchanged) size",
          "required": true,
          "schema": {
            "example": "0.02",
            "type": "string"
          }
        },
        {
          "name": "price",
          "description": "New (or unchanged) limit price",
          "required": true,
          "schema": {
            "example": "29600.00",
            "type": "string"
          }
        },
        {
          "name": "trigger_price",
          "description": "New (or unchanged) trigger price for TPSL orders",
          "required": false,
          "schema": {
            "example": "29000.00",
            "type": "string"
          }
        },
