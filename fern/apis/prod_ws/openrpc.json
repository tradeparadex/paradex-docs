{
  "openrpc": "1.3.2",
  "info": {
    "title": "Paradex WebSocket RPC API",
    "version": "1.1.0",
    "description": "JSON-RPC 2.0 methods for the Paradex WebSocket API. All requests follow the envelope: {\"jsonrpc\":\"2.0\",\"method\":\"\u003cname\u003e\",\"params\":{...},\"id\":\u003cint\u003e}. Responses include usIn/usOut/usDiff nanosecond timing fields."
  },
  "servers": [
    {
      "name": "production",
      "url": "wss://ws.api.prod.paradex.trade/v1",
      "description": "Production WebSocket server"
    },
    {
      "name": "testnet",
      "url": "wss://ws.api.testnet.paradex.trade/v1",
      "description": "Testnet WebSocket server"
    }
  ],
  "methods": [
    {
      "name": "auth",
      "summary": "Authenticate the WebSocket session",
      "description": "Validates the JWT bearer token and associates the account with the connection. Must be called before subscribing to private channels or using order management methods.",
      "tags": [
        {
          "name": "Session"
        }
      ],
      "paramStructure": "by-name",
      "params": [
        {
          "name": "bearer",
          "description": "JWT string obtained from POST /auth",
          "required": true,
          "schema": {
            "example": "eyJhbGci...",
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "properties": {
            "node_id": {
              "description": "Opaque server node identifier",
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "errors": [
        {
          "code": -32700,
          "message": "Parse error"
        },
        {
          "code": -32600,
          "message": "Invalid request"
        },
        {
          "code": -32601,
          "message": "Method not found"
        },
        {
          "code": -32602,
          "message": "Invalid method parameters"
        },
        {
          "code": -32603,
          "message": "Internal error"
        },
        {
          "code": 40110,
          "message": "Malformed bearer token"
        },
        {
          "code": 40111,
          "message": "Invalid bearer token"
        },
        {
          "code": 40112,
          "message": "Geo IP blocked"
        }
      ]
    },
    {
      "name": "subscribe",
      "summary": "Subscribe to a WebSocket channel",
      "description": "Starts receiving real-time messages for the given channel. Private channels (orders, fills, positions, account, etc.) require prior authentication. See the WebSocket Channels reference for all available channel names.",
      "tags": [
        {
          "name": "Session"
        }
      ],
      "paramStructure": "by-name",
      "params": [
        {
          "name": "channel",
          "description": "Channel name to subscribe to (e.g. trades.BTC-USD-PERP)",
          "required": true,
          "schema": {
            "example": "trades.BTC-USD-PERP",
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "properties": {
            "channel": {
              "description": "Channel name that was subscribed",
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "errors": [
        {
          "code": -32700,
          "message": "Parse error"
        },
        {
          "code": -32600,
          "message": "Invalid request"
        },
        {
          "code": -32601,
          "message": "Method not found"
        },
        {
          "code": -32602,
          "message": "Invalid method parameters"
        },
        {
          "code": -32603,
          "message": "Internal error"
        },
        {
          "code": 40110,
          "message": "Malformed bearer token"
        },
        {
          "code": 40111,
          "message": "Invalid bearer token"
        },
        {
          "code": 40112,
          "message": "Geo IP blocked"
        }
      ]
    },
    {
      "name": "unsubscribe",
      "summary": "Unsubscribe from a WebSocket channel",
      "tags": [
        {
          "name": "Session"
        }
      ],
      "paramStructure": "by-name",
      "params": [
        {
          "name": "channel",
          "description": "Channel name to unsubscribe from",
          "required": true,
          "schema": {
            "example": "trades.BTC-USD-PERP",
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "properties": {
            "channel": {
              "description": "Channel name that was unsubscribed",
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "errors": [
        {
          "code": -32700,
          "message": "Parse error"
        },
        {
          "code": -32600,
          "message": "Invalid request"
        },
        {
          "code": -32601,
          "message": "Method not found"
        },
        {
          "code": -32602,
          "message": "Invalid method parameters"
        },
        {
          "code": -32603,
          "message": "Internal error"
        },
        {
          "code": 40110,
          "message": "Malformed bearer token"
        },
        {
          "code": 40111,
          "message": "Invalid bearer token"
        },
        {
          "code": 40112,
          "message": "Geo IP blocked"
        }
      ]
    },
    {
      "name": "order.create",
      "summary": "Submit a new order",
      "description": "Creates a single order. Requires authentication and a valid Starknet signature over the order payload. Rate limits are shared with the REST API (same Redis counters).",
      "tags": [
        {
          "name": "Order Management"
        }
      ],
      "paramStructure": "by-name",
      "params": [
        {
          "name": "market",
          "description": "Market symbol",
          "required": true,
          "schema": {
            "example": "BTC-USD-PERP",
            "type": "string"
          }
        },
        {
          "name": "side",
          "description": "Order side",
          "required": true,
          "schema": {
            "enum": [
              "BUY",
              "SELL"
            ],
            "type": "string"
          }
        },
        {
          "name": "type",
          "description": "Order type",
          "required": true,
          "schema": {
            "enum": [
              "LIMIT",
              "MARKET",
              "STOP_LIMIT",
              "STOP_MARKET"
            ],
            "type": "string"
          }
        },
        {
          "name": "size",
          "description": "Order size (decimal string)",
          "required": true,
          "schema": {
            "example": "0.01",
            "type": "string"
          }
        },
        {
          "name": "price",
          "description": "Limit price; use \"0\" for MARKET orders",
          "required": true,
          "schema": {
            "example": "29500.00",
            "type": "string"
          }
        },
        {
          "name": "instruction",
          "description": "Time-in-force instruction",
          "required": true,
          "schema": {
            "enum": [
              "GTC",
              "IOC",
              "POST_ONLY",
              "RPI"
            ],
            "type": "string"
          }
        },
        {
          "name": "signature",
          "description": "Starknet signature \"[r,s]\" over the order payload",
          "required": true,
          "schema": {
            "example": "[r_value,s_value]",
            "type": "string"
          }
        },
        {
          "name": "signature_timestamp",
          "description": "Unix timestamp in milliseconds used for signature verification",
          "required": true,
          "schema": {
            "example": "1696291200000",
            "type": "integer"
          }
        },
        {
          "name": "client_id",
          "description": "Client-assigned order ID (max 64 chars)",
          "required": false,
          "schema": {
            "example": "my-order-001",
            "type": "string"
          }
        },
        {
          "name": "stp",
          "description": "Self-trade prevention",
          "required": false,
          "schema": {
            "enum": [
              "EXPIRE_MAKER",
              "EXPIRE_TAKER",
              "EXPIRE_BOTH"
            ],
            "type": "string"
          }
        },
        {
          "name": "recv_window",
          "description": "Max milliseconds between signature_timestamp and server receipt (min 10)",
          "required": false,
          "schema": {
            "type": "integer"
          }
        },
        {
          "name": "flags",
          "description": "Order flags",
          "required": false,
          "schema": {
            "enum": [
              "REDUCE_ONLY"
            ],
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        {
          "name": "trigger_price",
          "description": "Trigger price for stop orders",
          "required": false,
          "schema": {
            "example": "29000.00",
            "type": "string"
          }
        },
        {
          "name": "on_behalf_of_account",
          "description": "Isolated margin account address for isolated margin orders",
          "required": false,
          "schema": {
            "example": "0x1234567890abcdef",
            "type": "string"
          }
        }
      ],
      "result": {
        "name": "result",
        "schema": {
          "properties": {
            "created_at": {
              "description": "Matching-engine timestamp in milliseconds",
              "example": "1696291200000",
              "type": "integer"
            },
            "order": {
              "description": "Created order",
              "properties": {
                "account": {
                  "description": "Account address that owns the order",
                  "example": "0x4638e30...",
                  "type": "string"
                },
                "avg_fill_price": {
                  "description": "Volume-weighted average fill price; \"0\" if unfilled",
                  "example": "0",
                  "type": "string"
                },
                "cancel_reason": {
                  "description": "Reason for cancellation (populated when status=CLOSED)",
                  "example": "USER_CANCELED",
                  "type": "string"
                },
                "client_id": {
                  "description": "Client-assigned order ID",
                  "example": "my-order-001",
                  "type": "string"
                },
                "created_at": {
                  "description": "Order creation time in milliseconds",
                  "example": "1696291200000",
                  "type": "integer"
                },
                "flags": {
                  "description": "Order flags applied",
                  "example": "[\"REDUCE_ONLY\"]",
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "id": {
                  "description": "Unique order identifier assigned by exchange",
                  "example": "1234567890",
                  "type": "string"
                },
                "instruction": {
                  "description": "Time-in-force instruction",
                  "enum": [
                    "GTC",
                    "IOC",
                    "POST_ONLY",
                    "RPI"
                  ],
                  "type": "string"
                },
                "last_updated_at": {
                  "description": "Order last update time in milliseconds",
                  "example": "1696291200000",
                  "type": "integer"
                },
                "market": {
                  "description": "Market symbol",
                  "example": "BTC-USD-PERP",
                  "type": "string"
                },
                "price": {
                  "description": "Limit price",
                  "example": "29500.00",
                  "type": "string"
                },
                "published_at": {
                  "description": "Exchange publish time in milliseconds",
                  "example": "1696291200000",
                  "type": "integer"
                },
                "received_at": {
                  "description": "Exchange receipt time in milliseconds",
                  "example": "1696291200000",
                  "type": "integer"
                },
                "remaining_size": {
                  "description": "Remaining unfilled size",
                  "example": "0.01",
                  "type": "string"
                },
                "seq_no": {
                  "description": "Monotonically increasing sequence number for this order's updates",
                  "example": "20784",
                  "type": "integer"
                },
                "side": {
                  "description": "Order side",
                  "enum": [
                    "BUY",
                    "SELL"
                  ],
                  "type": "string"
                },
                "size": {
                  "description": "Order size",
                  "example": "0.01",
                  "type": "string"
                },
                "status": {
                  "description": "Order status",
                  "enum": [
                    "NEW",
                    "OPEN",
                    "CLOSED"
                  ],
                  "type": "string"
                },
                "timestamp": {
                  "description": "Signature timestamp supplied at creation",
                  "example": "1696291200000",
                  "type": "integer"
                },
                "trigger_price": {
                  "description": "Trigger price for stop orders",
                  "example": "29000.00",
                  "type": "string"
                },
                "type": {
                  "description": "Order type",
                  "enum": [
                    "LIMIT",
                    "MARKET",
                    "STOP_LIMIT",
                    "STOP_MARKET"
                  ],
                  "type": "string"
                }
              },
              "type": "object"
            },
            "received_at": {
              "description": "Server receipt timestamp in nanoseconds, recorded before any speedbump",
              "example": "1696291200123456789",
              "type": "integer"
            }
          },
          "type": "object"
        }
      },
      "errors": [
        {
          "code": -32700,
          "message": "Parse error"
        },
        {
          "code": -32600,
          "message": "Invalid request"
        },
        {
          "code": -32601,
          "message": "Method not found"
        },
        {
          "code": -32602,
          "message": "Invalid method parameters"
        },
        {
          "code": -32603,
          "message": "Internal error"
        },
        {
          "code": 40110,
          "message": "Malformed bearer token"
        },
        {
          "code": 40111,
          "message": "Invalid bearer token"
        },
        {
          "code": 40112,
          "message": "Geo IP blocked"
        },
        {
          "code": 40300,
          "message": "Permission denied — authentication required"
        },
        {
          "code": 42901,
          "message": "Rate limit exceeded"
        }
      ]
    },
    {
      "name": "order.create_batch",
      "summary": "Submit multiple orders in a single request",
      "description": "Creates up to the configured maximum number of orders atomically. All signatures are validated before any orders reach the matching engine. Rate limit is consumed once for the entire batch.",
      "tags": [
        {
          "name": "Order Management"
        }
      ],
      "paramStructure": "by-name",
      "params": [
        {
          "name": "orders",
