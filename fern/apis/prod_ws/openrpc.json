                    "POST_ONLY",
                    "RPI"
                  ],
                  "type": "string"
                },
                "market": {
                  "description": "Market symbol",
                  "example": "BTC-USD-PERP",
                  "type": "string"
                },
                "on_behalf_of_account": {
                  "description": "Isolated margin account address for isolated margin orders",
                  "example": "0x1234567890abcdef",
                  "type": "string"
                },
                "price": {
                  "description": "Limit price; use \"0\" for MARKET orders",
                  "example": "29500.00",
                  "type": "string"
                },
                "recv_window": {
                  "description": "Max milliseconds between signature_timestamp and server receipt (min 10)",
                  "type": "integer"
                },
                "side": {
                  "description": "Order side",
                  "enum": [
                    "BUY",
                    "SELL"
                  ],
                  "type": "string"
                },
                "signature": {
                  "description": "Starknet signature \"[r,s]\" over the order payload",
                  "example": "[r_value,s_value]",
                  "type": "string"
                },
                "signature_timestamp": {
                  "description": "Unix timestamp in milliseconds used for signature verification",
                  "example": "1696291200000",
                  "type": "integer"
                },
                "size": {
                  "description": "Order size (decimal string)",
                  "example": "0.01",
                  "type": "string"
                },
                "stp": {
                  "description": "Self-trade prevention",
                  "enum": [
                    "EXPIRE_MAKER",
                    "EXPIRE_TAKER",
                    "EXPIRE_BOTH"
                  ],
                  "type": "string"
                },
                "trigger_price": {
                  "description": "Trigger price for stop orders",
                  "example": "29000.00",
                  "type": "string"
                },
                "type": {
                  "description": "Order type",
                  "enum": [
                    "LIMIT",
                    "MARKET",
                    "STOP_LIMIT",
                    "STOP_MARKET"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "market",
                "side",
                "type",
                "size",
                "price",
                "instruction",
                "signature",
                "signature_timestamp"
              ],
              "type": "object"
            },
            "type": "array"
          }
        }
      ],
      "result": {
